{
  "name": "kindergarten-english-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "幼儿英语点读打卡网站 MVP",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @kindergarten-english/api & npm run dev -w @kindergarten-english/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "deploy:web": "bash infra/deploy-pages.sh"
  },
  "engines": {
    "node": ">=20"
  }
}
